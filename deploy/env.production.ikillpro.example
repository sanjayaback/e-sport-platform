# Production env for www.ikillpro.com

# This app uses Google Sheets, not MongoDB.
# Do not add MONGODB_URI unless you later add MongoDB code.

# Runtime
NODE_ENV=production
ALLOW_MOCK_GOOGLE_SHEETS=false

# JWT
JWT_SECRET=replace_with_a_new_long_random_secret

# Public App URL
NEXT_PUBLIC_APP_URL=https://www.ikillpro.com

# Email notifications - optional
# If you are not using email, you can leave these blank or remove them.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@ikillpro.com

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Google Sheets
# Keep GOOGLE_PRIVATE_KEY on a single line with literal \n separators.
GOOGLE_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n
GOOGLE_SHEET_ID=your_google_sheet_id

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
