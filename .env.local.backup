# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/esports_platform
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/esports_platform

# JWT Secret (generate with: openssl rand -base64 64)
